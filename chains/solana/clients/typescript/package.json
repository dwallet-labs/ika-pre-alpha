{
  "name": "@ika.xyz/pre-alpha-solana-client",
  "version": "0.1.0",
  "license": "BSD-3-Clause-Clear",
  "type": "module",
  "exports": {
    ".": "./src/generated/index.ts",
    "./grpc": "./src/grpc.ts",
    "./grpc-web": "./src/grpc-web.ts"
  },
  "scripts": {
    "generate": "protoc --plugin=./node_modules/.bin/protoc-gen-ts --ts_out=src/generated/grpc-web --proto_path=../../../../proto ../../../../proto/ika_dwallet.proto && protoc --plugin=./node_modules/.bin/protoc-gen-ts_proto --ts_proto_out=src/generated/grpc --ts_proto_opt=outputServices=grpc-js,esModuleInterop=true --proto_path=../../../../proto ../../../../proto/ika_dwallet.proto",
    "build": "bunx --bun tsc"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.11",
    "@grpc/grpc-js": "^1.12",
    "@mysten/bcs": "^2.0",
    "@protobuf-ts/grpcweb-transport": "^2.11",
    "@protobuf-ts/runtime": "^2.11",
    "@protobuf-ts/runtime-rpc": "^2.11"
  },
  "peerDependencies": {
    "@solana/kit": "^6.4",
    "typescript": "^5"
  },
  "devDependencies": {
    "@protobuf-ts/plugin": "^2.11",
    "ts-proto": "^2.11",
    "typescript": "^5"
  }
}
